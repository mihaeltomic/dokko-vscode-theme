  "semanticHighlighting": true,
  "semanticTokenColors": {
    "function": "#DCDCAA",
    "method": "#DCDCAA",
    "class": "#4EC9B0",
    "interface": "#4EC9B0",
    "enum": "#4EC9B0",
    "type": "#4EC9B0",
    "typeParameter": "#4EC9B0",
    "namespace": "#4EC9B0",
    "variable": "#9CDCFE",
    "parameter": "#9CDCFE",
    "property": "#9CDCFE",
    "enumMember": "#4FC1FF",
    "property:json": "#bffd6d",
    "keyword": "#bffd6d",
    "modifier": "#bffd6d",
    "decorator": "#bffd6d",
    "number": "#b5cea8",
    "string": "#ce9178",
    "comment": "#6A9955",
    "macro": "#bffd6d",
    "selfKeyword": "#bffd6d",
    "variable.readonly": "#4FC1FF",
    "newOperator": "#bffd6d",
    "stringLiteral": "#ce9178",
    "numberLiteral": "#b5cea8"
  },
  "tokenColors": [
    {
      "scope": ["meta.embedded", "source.groovy.embedded"],
      "settings": { "foreground": "#D4D4D4" }
    },
    {
      "scope": "comment",
      "settings": { "foreground": "#6A9955", "fontStyle": "italic" }
    },
    {
      "scope": "constant.language",
      "settings": { "foreground": "#569cd6" }
    },
    {
      "scope": ["constant.numeric", "keyword.operator.plus.exponent", "keyword.operator.minus.exponent"],
      "settings": { "foreground": "#b5cea8" }
    },
    {
      "scope": "constant.regexp",
      "settings": { "foreground": "#646695" }
    },
    {
      "name": "HTML / JSX tags",
      "scope": "entity.name.tag",
      "settings": { "foreground": "#bffd6d" }
    },
    {
      "scope": ["entity.name.tag.css", "entity.name.tag.less"],
      "settings": { "foreground": "#d7ba7d" }
    },
    {
      "scope": "entity.other.attribute-name",
      "settings": { "foreground": "#9cdcfe" }
    },
    {
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css",
        "entity.other.attribute-name.scss"
      ],
      "settings": { "foreground": "#d7ba7d" }
    },
    {
      "scope": "invalid",
      "settings": { "foreground": "#f44747" }
    },
    {
      "scope": "markup.bold",
      "settings": { "fontStyle": "bold", "foreground": "#569cd6" }
    },
    {
      "scope": "markup.heading",
      "settings": { "fontStyle": "bold", "foreground": "#bffd6d" }
    },
    {
      "scope": "markup.italic",
      "settings": { "fontStyle": "italic" }
    },
    {
      "scope": "markup.strikethrough",
      "settings": { "fontStyle": "strikethrough" }
    },
    {
      "scope": "markup.inserted",
      "settings": { "foreground": "#b5cea8" }
    },
    {
      "scope": "markup.deleted",
      "settings": { "foreground": "#ce9178" }
    },
    {
      "scope": "markup.changed",
      "settings": { "foreground": "#bffd6d" }
    },
    {
      "scope": "markup.inline.raw",
      "settings": { "foreground": "#ce9178" }
    },
    {
      "scope": "punctuation.definition.quote.begin.markdown",
      "settings": { "foreground": "#6A9955" }
    },
    {
      "scope": "punctuation.definition.tag",
      "settings": { "foreground": "#808080" }
    },
    {
      "scope": ["storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#bffd6d" }
    },
    {
      "scope": ["string", "meta.embedded.assembly"],
      "settings": { "foreground": "#ce9178" }
    },
    {
      "scope": "string.regexp",
      "settings": { "foreground": "#d16969" }
    },
    {
      "name": "String interpolation / template expression",
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end",
        "punctuation.section.embedded"
      ],
      "settings": { "foreground": "#bffd6d" }
    },
    {
      "name": "Reset template expression body",
      "scope": "meta.template.expression",
      "settings": { "foreground": "#d4d4d4" }
    },
    {
      "scope": ["support.type.property-name", "source.css variable", "source.coffee.embedded"],
      "settings": { "foreground": "#9cdcfe" }
    },
    {
      "scope": ["keyword", "keyword.control"],
      "settings": { "foreground": "#bffd6d" }
    },
    {
      "scope": "keyword.operator",
      "settings": { "foreground": "#d4d4d4" }
    },
    {
      "scope": [
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.cast",
        "keyword.operator.sizeof",
        "keyword.operator.instanceof",
        "keyword.operator.logical.python",
        "keyword.operator.wordlike"
      ],
      "settings": { "foreground": "#bffd6d" }
    },
    {
      "scope": "keyword.other.unit",
      "settings": { "foreground": "#b5cea8" }
    },
    {
      "scope": "variable.language",
      "settings": { "foreground": "#bffd6d" }
    },
    {
      "name": "Functions",
      "scope": ["entity.name.function", "support.function", "entity.name.operator.custom-literal"],
      "settings": { "foreground": "#DCDCAA" }
    },
    {
      "name": "Types / classes",
      "scope": [
        "support.class", "support.type",
        "entity.name.type", "entity.name.namespace", "entity.name.class",
        "entity.other.inherited-class"
      ],
      "settings": { "foreground": "#4EC9B0" }
    },
    {
      "name": "Control flow keywords",
      "scope": "keyword.control",
      "settings": { "foreground": "#bffd6d" }
    },
    {
      "name": "Variables and parameters",
      "scope": [
        "variable", "meta.definition.variable.name",
        "support.variable", "entity.name.variable",
        "constant.other.placeholder"
      ],
      "settings": { "foreground": "#9CDCFE" }
    },
    {
      "name": "Constants and enum members",
      "scope": ["variable.other.constant", "variable.other.enummember"],
      "settings": { "foreground": "#4FC1FF" }
    },
    {
      "name": "Object literal keys",
      "scope": "meta.object-literal.key",
      "settings": { "foreground": "#9CDCFE" }
    },
    {
      "name": "CSS property values",
      "scope": [
        "support.constant.property-value", "support.constant.font-name",
        "support.constant.media-type", "support.constant.color",
        "constant.other.color.rgb-value"
      ],
      "settings": { "foreground": "#CE9178" }
    },
    {
      "name": "Regex groups",
      "scope": [
        "punctuation.definition.group.regexp",
        "punctuation.definition.group.assertion.regexp",
        "punctuation.definition.character-class.regexp",
        "punctuation.character.set.begin.regexp",
        "punctuation.character.set.end.regexp",
        "support.other.parenthesis.regexp"
      ],
      "settings": { "foreground": "#CE9178" }
    },
    {
      "scope": [
        "constant.character.character-class.regexp",
        "constant.other.character-class.regexp"
      ],
      "settings": { "foreground": "#d16969" }
    },
    {
      "scope": "keyword.operator.quantifier.regexp",
      "settings": { "foreground": "#d7ba7d" }
    },
    {
      "scope": "constant.character.escape",
      "settings": { "foreground": "#d7ba7d" }
    },
    {
      "name": "Decorators",
      "scope": ["meta.decorator", "punctuation.decorator"],
      "settings": { "foreground": "#bffd6d" }
    }
  ]
}
